<UserControl x:Class="AttendanceSystem.WPF.Views.Devices.DevicesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
    <Grid Margin="20">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <Button Grid.Column="0" Command="{Binding BackToDashboardCommand}" Style="{DynamicResource MahApps.Styles.Button.Circle}" Width="40" Height="40" Margin="0,0,15,0">
                <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="20" Height="20"/>
            </Button>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Gestión de Dispositivos" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="Administre los dispositivos de asistencia" FontSize="14" Foreground="{DynamicResource MahApps.Brushes.Gray}"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Command="{Binding RefreshCommand}" Style="{DynamicResource MahApps.Styles.Button.Square}" Width="40" Height="40" Margin="0,0,10,0">
                    <iconPacks:PackIconMaterial Kind="Refresh" Width="20" Height="20"/>
                </Button>
                <Button Command="{Binding AddDeviceCommand}" Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" Height="40" Padding="15,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Plus" Width="20" Height="20" Margin="0,0,5,0"/>
                        <TextBlock Text="Nuevo Dispositivo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
        <DataGrid Grid.Row="1" ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" AlternatingRowBackground="{DynamicResource MahApps.Brushes.Gray10}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="130"/>
                <DataGridTextColumn Header="Puerto" Binding="{Binding Port}" Width="80"/>
                <DataGridTextColumn Header="Sucursal" Binding="{Binding BranchName}" Width="150"/>
                <DataGridCheckBoxColumn Header="Activo" Binding="{Binding IsActive}" Width="70"/>
                <DataGridTextColumn Header="Estado" Binding="{Binding Status}" Width="120"/>
                <DataGridTextColumn Header="Última Sync" Binding="{Binding LastSync, StringFormat='dd/MM/yyyy HH:mm'}" Width="140"/>
                <DataGridTemplateColumn Header="Acciones" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Command="{Binding DataContext.TestConnectionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{DynamicResource MahApps.Styles.Button.Circle}" Width="32" Height="32" Margin="2" ToolTip="Probar Conexión"><iconPacks:PackIconMaterial Kind="Connection" Width="14" Height="14"/></Button>
                                <Button Command="{Binding DataContext.DownloadLogsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{DynamicResource MahApps.Styles.Button.Circle}" Width="32" Height="32" Margin="2" ToolTip="Descargar Logs"><iconPacks:PackIconMaterial Kind="Download" Width="14" Height="14"/></Button>
                                <Button Command="{Binding DataContext.EditDeviceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{DynamicResource MahApps.Styles.Button.Circle}" Width="32" Height="32" Margin="2" ToolTip="Editar"><iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/></Button>
                                <Button Command="{Binding DataContext.DeleteDeviceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{DynamicResource MahApps.Styles.Button.Circle}" Width="32" Height="32" Margin="2" ToolTip="Eliminar"><iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14"/></Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Row="0" Grid.RowSpan="2" Background="#80000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <mah:ProgressRing IsActive="{Binding IsBusy}" Width="60" Height="60" Foreground="White"/>
                <TextBlock Text="{Binding BusyMessage}" Foreground="White" FontSize="16" Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
