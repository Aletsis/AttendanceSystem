<UserControl x:Class="AttendanceSystem.WPF.Views.Attendance.AttendanceView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
    <Grid Margin="20">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <Button Grid.Column="0" Command="{Binding BackToDashboardCommand}" Style="{DynamicResource MahApps.Styles.Button.Circle}" Width="40" Height="40" Margin="0,0,15,0">
                <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="20" Height="20"/>
            </Button>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Registros de Asistencia" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="Visualice y gestione los registros de asistencia" FontSize="14" Foreground="{DynamicResource MahApps.Brushes.Gray}"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Command="{Binding ManualEntryCommand}" Style="{DynamicResource MahApps.Styles.Button.Square}" Height="40" Padding="15,0" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ClipboardEdit" Width="20" Height="20" Margin="0,0,5,0"/>
                        <TextBlock Text="Registro Manual" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding CalculateAttendanceCommand}" Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" Height="40" Padding="15,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Calculator" Width="20" Height="20" Margin="0,0,5,0"/>
                        <TextBlock Text="Calcular Asistencia" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,15,0">
                <TextBlock Text="Desde:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <DatePicker SelectedDate="{Binding StartDate}" Width="140"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,15,0">
                <TextBlock Text="Hasta:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <DatePicker SelectedDate="{Binding EndDate}" Width="140"/>
            </StackPanel>
            <TextBox Grid.Column="2" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" mah:TextBoxHelper.Watermark="Buscar empleado..." mah:TextBoxHelper.ClearTextButton="True" FontSize="14" Padding="10" Margin="0,0,10,0"/>
            <Button Grid.Column="3" Command="{Binding ExportCommand}" Style="{DynamicResource MahApps.Styles.Button.Square}" Width="40" Height="40" Margin="0,0,10,0" ToolTip="Exportar">
                <iconPacks:PackIconMaterial Kind="FileExport" Width="20" Height="20"/>
            </Button>
            <Button Grid.Column="4" Command="{Binding RefreshCommand}" Style="{DynamicResource MahApps.Styles.Button.Square}" Width="40" Height="40">
                <iconPacks:PackIconMaterial Kind="Refresh" Width="20" Height="20"/>
            </Button>
        </Grid>
        <DataGrid Grid.Row="2" ItemsSource="{Binding AttendanceLogs}" SelectedItem="{Binding SelectedLog}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" AlternatingRowBackground="{DynamicResource MahApps.Brushes.Gray10}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="No. Empleado" Binding="{Binding EmployeeNumber}" Width="120"/>
                <DataGridTextColumn Header="Empleado" Binding="{Binding EmployeeName}" Width="*"/>
                <DataGridTextColumn Header="Fecha" Binding="{Binding Date, StringFormat='dd/MM/yyyy'}" Width="100"/>
                <DataGridTextColumn Header="Entrada" Binding="{Binding EntryTime}" Width="100"/>
                <DataGridTextColumn Header="Salida" Binding="{Binding ExitTime}" Width="100"/>
                <DataGridTextColumn Header="Horas" Binding="{Binding WorkedHours}" Width="80"/>
                <DataGridTextColumn Header="Estado" Binding="{Binding Status}" Width="120"/>
                <DataGridTextColumn Header="Notas" Binding="{Binding Notes}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Row="0" Grid.RowSpan="3" Background="#80000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <mah:ProgressRing IsActive="{Binding IsBusy}" Width="60" Height="60" Foreground="White"/>
                <TextBlock Text="{Binding BusyMessage}" Foreground="White" FontSize="16" Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
