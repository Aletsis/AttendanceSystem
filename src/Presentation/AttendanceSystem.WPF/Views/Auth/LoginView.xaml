<UserControl x:Class="AttendanceSystem.WPF.Views.Auth.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1" 
                Background="{DynamicResource MahApps.Brushes.Tile}"
                CornerRadius="10"
                Padding="40"
                MaxWidth="450"
                Margin="20">
            <StackPanel>
                <iconPacks:PackIconMaterial Kind="AccountCircle" 
                                          Width="80" 
                                          Height="80"
                                          Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                          HorizontalAlignment="Center"
                                          Margin="0,0,0,20"/>
                
                <TextBlock Text="Sistema de Asistencia" 
                          FontSize="24" 
                          FontWeight="Bold"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,10"/>
                
                <TextBlock Text="Iniciar Sesión" 
                          FontSize="16"
                          HorizontalAlignment="Center"
                          Foreground="{DynamicResource MahApps.Brushes.Gray}"
                          Margin="0,0,0,30"/>

                <TextBlock Text="Usuario" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Username}" 
                         mah:TextBoxHelper.ClearTextButton="True"
                         mah:TextBoxHelper.Watermark="Ingrese su usuario"
                         FontSize="14"
                         Padding="10,8"
                         Margin="0,0,0,20"/>

                <TextBlock Text="Contraseña" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox"
                            mah:TextBoxHelper.ClearTextButton="True"
                            mah:TextBoxHelper.Watermark="Ingrese su contraseña"
                            FontSize="14"
                            Padding="10,8"
                            Margin="0,0,0,20"/>

                <Button Content="Iniciar Sesión"
                       Command="{Binding LoginCommand}"
                       CommandParameter="{Binding ElementName=PasswordBox}"
                       Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                       FontSize="16"
                       Padding="20,12"/>
            </StackPanel>
        </Border>

        <!-- Busy Indicator Overlay -->
        <Grid Grid.RowSpan="3" Background="#80000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <mah:ProgressRing IsActive="{Binding IsBusy}" Width="60" Height="60" Foreground="White" Margin="0,0,0,15"/>
                <TextBlock Text="{Binding BusyMessage}" Foreground="White" HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
